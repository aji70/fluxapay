// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Merchant {
  id                    String                 @id @default(cuid())
  business_name         String
  email                 String                 @unique
  phone_number          String                 @unique
  country               String
  settlement_currency   String
  webhook_url           String?
  webhook_secret        String
  password              String
  status                MerchantStatus         @default(pending_verification)
  api_key_hashed        String?
  api_key_last_four     String?
  settlement_schedule   String?                @default("daily")
  settlement_day        Int?
  /** FluxaPay fee percentage for this merchant (default 1.5%) */
  settlement_fee_percent Decimal               @default(1.5)
  /** HTTPS URL of logo shown on hosted checkout (/pay/:id). */
  checkout_logo_url     String?
  /** Primary accent for hosted checkout, e.g. #RRGGBB or #RGB. */
  checkout_accent_color String?
  /** Email notification preferences */
  email_notifications_enabled Boolean            @default(true)
  notify_on_payment     Boolean                @default(false)
  notify_on_settlement  Boolean                @default(true)
  /** On-chain registry state — prevents duplicate Soroban registrations on retry */
  onchain_registered        Boolean   @default(false)
  onchain_registry_tx_hash  String?
  /** Compliance: set when merchant requests account deletion */
  deletion_requested_at DateTime?
  /** Compliance: set after PII anonymization is complete */
  anonymized_at         DateTime?
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  otps                  OTP[]
  settlements           Settlement[]
  kyc                   MerchantKYC?
  webhookLogs           WebhookLog[]
  payments              Payment[]
  refunds               Refund[]
  invoices              Invoice[]
  bankAccount           BankAccount?
  merchantHDIndex       MerchantHDIndex?
  subscriptions         MerchantSubscription[]
  reconciliationRecords ReconciliationRecord[]
  discrepancyThresholds DiscrepancyThreshold[]
  discrepancyAlerts     DiscrepancyAlert[]
  customers             Customer[]
  dataExportJobs        DataExportJob[]
  paymentLinks          PaymentLink[]
  dailyReconciliationReports DailyReconciliationReport[]
  apiKeys               ApiKey[]
  refreshTokens            RefreshToken[]
  usagePeriods          MerchantUsagePeriod[]
}

model Customer {
  id              String   @id @default(cuid())
  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId      String
  email           String
  name            String?
  phone           String?
  stellar_address String?
  metadata        Json     @default("{}")
  deleted_at      DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  payments        Payment[]
  paymentLinks    PaymentLink[]

  @@index([merchantId])
  @@index([merchantId, email])
  @@index([deleted_at])
  @@unique([merchantId, email])
}

model PaymentLink {
  id             String   @id @default(cuid())
  merchant       Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId     String
  slug           String   @unique
  title          String
  description    String?
  amount         Decimal?
  currency       String
  redirect_url   String?
  expiry         DateTime?
  active         Boolean  @default(true)
  metadata       Json     @default("{}")
  total_payments Int      @default(0)
  total_volume   Decimal  @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  payments       Payment[]
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])

  @@index([merchantId])
  @@index([slug])
  @@index([active])
  @@index([expiry])
}

model MerchantHDIndex {
  merchantId      String   @id
  merchant        Merchant @relation(fields: [merchantId], references: [id])
  merchant_index  Int      @unique
  payment_counter Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model HDIndexCounter {
  id                   String   @id @default("global")
  next_merchant_index  Int      @default(0)
  updated_at           DateTime @updatedAt
}

model ManualIntervention {
  id          String   @id @default(cuid())
  merchantId  String
  issue_type  String
  description String
  status      String   @default("pending")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model BankAccount {
  id             String   @id @default(cuid())
  merchant       Merchant @relation(fields: [merchantId], references: [id])
  merchantId     String   @unique
  account_name   String
  account_number String
  bank_name      String
  bank_code      String?
  currency       String
  country        String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

model Plan {
  id                      String                 @id @default(cuid())
  name                    String
  slug                    String                 @unique
  description             String?
  amount                  Decimal
  currency                String
  interval                String                 // monthly, yearly
  is_active               Boolean                @default(true)
  /** Monthly API call quota (null = unlimited) */
  api_call_limit          Int?
  /** Monthly charge creation quota (null = unlimited) */
  charge_limit            Int?
  /** Monthly settlement volume quota in USDC (null = unlimited) */
  settlement_volume_limit Decimal?
  /** hard_block | soft_overage */
  overage_mode            String                 @default("hard_block")
  /** Feature flags, e.g. ["data_export_pii"] */
  features                Json                   @default("[]")
  created_at              DateTime               @default(now())
  updated_at              DateTime               @updatedAt
  subscriptions           MerchantSubscription[]
}

/// Per-merchant usage counters for the current billing period.
model MerchantUsagePeriod {
  id                 String   @id @default(cuid())
  merchant           Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId         String
  period_start       DateTime
  period_end         DateTime
  api_calls          Int      @default(0)
  charges_created    Int      @default(0)
  settlement_volume  Decimal  @default(0)
  warning_80_sent_at DateTime?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@unique([merchantId, period_start])
  @@index([merchantId])
}

model MerchantSubscription {
  id                   String   @id @default(cuid())
  merchant             Merchant @relation(fields: [merchantId], references: [id])
  merchantId           String
  plan                 Plan     @relation(fields: [planId], references: [id])
  planId               String
  status               String   @default("active")
  billing_cycle        String
  current_period_start DateTime
  current_period_end   DateTime
  next_billing_date    DateTime
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
}

model AuditLog {
  id          String          @id @default(cuid())
  admin_id    String
  action_type AuditActionType
  entity_type AuditEntityType
  entity_id   String
  details     Json
  created_at  DateTime        @default(now())

  @@index([admin_id, created_at(sort: Desc)])
  @@index([entity_id, action_type])
}

model OTP {
  id         String     @id @default(cuid())
  merchant   Merchant   @relation(fields: [merchantId], references: [id])
  merchantId String
  channel    OTPChannel
  code       String
  expires_at DateTime
  created_at DateTime   @default(now())

  @@unique([merchantId, channel])
}

model Settlement {
  id               String           @id @default(cuid())
  merchant         Merchant         @relation(fields: [merchantId], references: [id])
  merchantId       String
  usdc_amount      Decimal?
  amount           Decimal
  fees             Decimal
  net_amount       Decimal?
  currency         String
  status           SettlementStatus @default(pending)
  exchange_partner String?
  exchange_rate    Decimal?
  exchange_ref     String?
  bank_transfer_id String?
  breakdown        Json?
  payment_ids      Json?
  failure_reason   String?
  payout_partner_payload Json?
  scheduled_date   DateTime
  processed_date   DateTime?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  payments         Payment[]

  @@index([merchantId, status])
  @@index([merchantId, scheduled_date(sort: Desc)])
}

model MerchantKYC {
  id                           String           @id @default(cuid())
  merchant                     Merchant         @relation(fields: [merchantId], references: [id])
  merchantId                   String           @unique
  business_type                BusinessType
  legal_business_name          String
  business_registration_number String?
  country_of_registration      String
  business_address             String
  director_full_name           String
  director_email               String
  director_phone               String
  government_id_type           GovernmentIdType
  government_id_number         String
  kyc_status                   KYCStatus        @default(not_submitted)
  rejection_reason             String?
  reviewed_at                  DateTime?
  reviewed_by                  String?
  documents                    KYCDocument[]
  created_at                   DateTime         @default(now())
  updated_at                   DateTime         @updatedAt
}

model KYCDocument {
  id            String       @id @default(cuid())
  kyc           MerchantKYC  @relation(fields: [kycId], references: [id])
  kycId         String
  document_type DocumentType
  file_name     String
  file_url      String
  public_id     String
  file_size     Int
  mime_type     String
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
}

model WebhookLog {
  id              String                @id @default(cuid())
  merchant        Merchant              @relation(fields: [merchantId], references: [id])
  merchantId      String
  event_type      WebhookEventType
  endpoint_url    String
  http_status     Int?
  status          WebhookStatus
  event_id        String?               @unique
  payment_id      String?
  retry_count     Int                   @default(0)
  max_retries     Int                   @default(5)
  next_retry_at   DateTime?
  request_payload Json?
  response_body   String?
  failed_at       DateTime?
  failure_reason  String?
  created_at      DateTime              @default(now())
  updated_at      DateTime              @updatedAt
  retryAttempts   WebhookRetryAttempt[]

  @@index([merchantId, created_at(sort: Desc)])
  @@index([merchantId, status])
  @@index([status, failed_at])
}

model WebhookRetryAttempt {
  id             String     @id @default(cuid())
  webhookLog     WebhookLog @relation(fields: [webhookLogId], references: [id])
  webhookLogId   String
  attempt_number Int
  http_status    Int?
  response_body  String?
  error_message  String?
  created_at     DateTime   @default(now())
}

model Payment {
  id                 String   @id @default(cuid())
  merchant           Merchant @relation(fields: [merchantId], references: [id])
  merchantId         String
  amount             Decimal
  currency           String
  usdc_amount        Decimal?
  fx_rate            Decimal?
  customer_email     String
  description        String?
  metadata           Json
  expiration         DateTime
  status             PaymentStatus   @default(pending)
  paid_amount        Decimal?        @default(0)
  last_seen_at       DateTime?
  checkout_url       String
  success_url        String?
  cancel_url         String?
  createdAt          DateTime @default(now())
  stellar_address    String?
  derivation_path    String?
  encrypted_key_data String?
  payment_index      Int?
  transaction_hash   String?
  contract_tx_hash   String?
  payer_address      String?
  onchain_verified   Boolean? @default(false)
  verification_error String?
  last_paging_token  String?
  swept              Boolean  @default(false)
  settled            Boolean  @default(false)
  swept_at           DateTime?
  sweep_tx_hash      String?
  confirmed_at       DateTime?
  settled_at         DateTime?
  settlement_ref     String?
  settlement_fiat_amount   Decimal?
  settlement_fiat_currency String?
  settlementId       String?
  settlement         Settlement? @relation(fields: [settlementId], references: [id])
  paymentLinkId      String?

  // reminder
  reminder_sent_at   DateTime?

  // webhook fields
  webhook_status     WebhookDeliveryStatus @default(PENDING)
  webhook_retries    Int                   @default(0)

  refunds            Refund[]
  invoice            Invoice?
  customerId         String?
  customer           Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  paymentLink        PaymentLink? @relation(fields: [paymentLinkId], references: [id])
  depositAddress     DepositAddress?

  // escrow fields
  escrow_mode              Boolean  @default(false)
  escrow_contract_address  String?
  escrow_status            String?

  @@index([swept, status])
  @@index([customerId])
  @@index([merchantId, createdAt(sort: Desc)])
  @@index([merchantId, status, createdAt(sort: Desc)])
}

model Refund {
  id            String       @id @default(cuid())
  merchant      Merchant     @relation(fields: [merchantId], references: [id])
  merchantId    String
  payment       Payment      @relation(fields: [paymentId], references: [id])
  paymentId     String
  amount        Decimal
  currency      String
  reason        String?
  status        RefundStatus @default(pending)
  failed_reason String?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  @@index([merchantId, status, created_at(sort: Desc)])
}

model Invoice {
  id             String        @id @default(cuid())
  merchant       Merchant      @relation(fields: [merchantId], references: [id])
  merchantId     String
  invoice_number String        @unique
  amount         Decimal
  currency       String
  subtotal       Decimal?
  tax_amount     Decimal?
  tax_rate       Decimal?
  customer_email String
  customer_name  String?
  line_items     Json?
  notes          String?
  metadata       Json?
  payment        Payment?      @relation(fields: [payment_id], references: [id])
  payment_id     String?       @unique
  payment_link   String
  status         InvoiceStatus @default(draft)
  due_date       DateTime?
  sent_at        DateTime?
  voided_at      DateTime?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  @@index([merchantId, created_at(sort: Desc)])
  @@index([merchantId, status, created_at(sort: Desc)])
}


model ReconciliationRecord {
  id                  String               @id @default(cuid())
  merchant            Merchant             @relation(fields: [merchantId], references: [id])
  merchantId          String
  period_start        DateTime
  period_end          DateTime
  expected_total      Decimal
  actual_total        Decimal
  discrepancy_amount  Decimal
  discrepancy_percent Decimal
  status              ReconciliationStatus @default(ok)
  alerts              DiscrepancyAlert[]
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt

  @@unique([merchantId, period_start, period_end])
}

model DailyReconciliationReport {
  id                  String   @id @default(cuid())
  merchant            Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId          String
  report_date         DateTime
  total_charges       Int      @default(0)
  total_volume_usdc   Decimal  @default(0)
  total_volume_fiat   Decimal  @default(0)
  total_fees          Decimal  @default(0)
  total_net_settled  Decimal  @default(0)
  report_data         Json     @default("{}")
  csv_url             String?
  emailed_at          DateTime?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@unique([merchantId, report_date])
  @@index([merchantId])
  @@index([report_date])
}

model DiscrepancyThreshold {
  id                String             @id @default(cuid())
  merchant          Merchant?          @relation(fields: [merchantId], references: [id])
  merchantId        String?
  amount_threshold  Decimal            @default(0)
  percent_threshold Decimal            @default(0)
  is_active         Boolean            @default(true)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  alerts            DiscrepancyAlert[]

  @@index([merchantId, is_active])
}

model DiscrepancyAlert {
  id                     String                @id @default(cuid())
  merchant               Merchant              @relation(fields: [merchantId], references: [id])
  merchantId             String
  reconciliationRecord   ReconciliationRecord  @relation(fields: [reconciliationRecordId], references: [id])
  reconciliationRecordId String
  threshold              DiscrepancyThreshold? @relation(fields: [thresholdId], references: [id])
  thresholdId            String?
  severity               AlertSeverity
  message                String
  is_resolved            Boolean               @default(false)
  resolved_at            DateTime?
  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt

  @@index([merchantId, is_resolved])
}

enum PaymentStatus {
  pending
  partially_paid
  confirmed
  overpaid
  expired
  failed
  paid
  completed
}

model CronLock {
  job_name   String   @id
  locked_at  DateTime
  expires_at DateTime
  locked_by  String   // hostname/pid for diagnostics
}


model IdempotencyRecord {
  idempotency_key  String   @id
  user_id          String?
  request_hash     String
  response_code    Int
  response_body    Json
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
}

enum MerchantStatus {
  pending_verification
  active
}

enum OTPChannel {
  email
  phone
}

enum SettlementStatus {
  pending
  processing
  completed
  failed
}

enum BusinessType {
  individual
  registered_business
}

enum GovernmentIdType {
  passport
  national_id
  driver_license
}

enum KYCStatus {
  not_submitted
  pending_review
  approved
  rejected
}

enum DocumentType {
  government_id
  proof_of_business_registration
  proof_of_address
}

enum WebhookEventType {
  payment_completed
  payment_failed
  payment_pending
  payment_expired
  payment_partially_paid
  payment_overpaid
  payment_settled
  refund_completed
  refund_failed
  settlement_completed
  settlement_failed
  subscription_created
  subscription_cancelled
  subscription_renewed
  invoice_paid
  invoice_overdue
  payment_escrow_released
  payment_escrow_refunded
  payment_escrow_expired
}

enum WebhookStatus {
  pending
  delivered
  failed
  retrying
}

enum RefundStatus {
  pending
  processing
  completed
  failed
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  voided
}

enum ReconciliationStatus {
  ok
  discrepancy
  discrepancy_detected
}

enum AlertSeverity {
  low
  medium
  high
  critical
}

enum AuditActionType {
  kyc_approve
  kyc_reject
  kyc_decision // merged from other
  config_change
  sweep_trigger
  sweep_complete
  sweep_fail
  sweep_operation // merged from other
  settlement_batch
  settlement_batch_initiate
  settlement_batch_complete
  settlement_batch_fail
  merchant_deletion_requested
  merchant_anonymized
  merchant_profile_updated
  bank_account_updated
  api_key_rotated
  webhook_secret_rotated
  // Database backup lifecycle
  db_backup_started
  db_backup_success
  db_backup_failed
  db_backup_retention_purge
  data_export_requested
  data_export_completed
  data_export_failed
  data_export_downloaded
}

enum AuditEntityType {
  merchant
  merchant_kyc
  system_config
  payment_gateway
  settlement
  sweep_operation
  settlement_batch
  merchant_account
  bank_account
  api_key
  webhook_secret
  database_backup
  data_export_job
}

/// Tracks a merchant's right-to-erasure request.
/// Financial records are retained under legal hold; only PII is anonymized.
/**
 * Per-merchant notification preferences.
 * Created on first write; absence means all defaults apply (reminders enabled).
 */
model MerchantNotificationPreferences {
  merchantId                   String   @id
  /// Whether to send payment-expiry reminder emails/webhooks (default: true)
  payment_expiry_reminder      Boolean  @default(true)
  /// Minutes before expiry to send the reminder (default: 5, min: 1)
  reminder_minutes_before      Int      @default(5)
  created_at                   DateTime @default(now())
  updated_at                   DateTime @updatedAt
}

model MerchantDeletionRequest {
  id           String    @id @default(cuid())
  merchantId   String    @unique
  reason       String?
  requested_by String    // "merchant" | "admin:<id>"
  /// Set when PII anonymization is executed
  executed_at  DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([merchantId])
}

/// Async GDPR-style data export job for a merchant.
model DataExportJob {
  id           String           @id @default(cuid())
  merchant     Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId   String
  status       DataExportStatus @default(pending)
  /// Base64-encoded JSON payload — populated when status = completed.
  payload      String?
  error        String?
  requested_by String
  expires_at   DateTime
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt

  @@index([merchantId])
}

enum DataExportStatus {
  pending
  processing
  completed
  failed
}

/// Internal operator accounts with role-based access control.
/// No production rollout until reviewed — spike only.
model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  /// bcrypt-hashed password
  password     String
  role         AdminRole
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
}

/// Roles for internal FluxaPay operators.
/// - support: read-only access to KYC submissions, payments, audit logs
/// - finance: read + write access to settlements, reconciliation, payouts
/// - super_admin: full access (future use)
enum AdminRole {
  support
  finance
  super_admin
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

model ApiKey {
  id                String   @id @default(cuid())
  merchant          Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId        String
  name              String
  /** SHA-256 hash of the API key */
  key_hash          String   @unique
  /** Last 4 characters of the key for display */
  key_last_four     String
  /** Environment: live or test */
  environment       ApiKeyEnvironment
  /** Status: active or revoked */
  status            ApiKeyStatus            @default(active)
  /** Timestamp when the key was last used for authentication */
  last_used_at      DateTime?
  created_at        DateTime               @default(now())
  updated_at        DateTime               @updatedAt

  @@index([merchantId])
  @@index([merchantId, status])
  @@index([key_hash])
}

enum ApiKeyEnvironment {
  live
  test
}

enum ApiKeyStatus {
  active
  revoked
}

enum EscrowStatus {
  pending
  active
  released
  refunded
  expired
}

model WorkerState {
  key   String @id
  value String
}

/// Refresh tokens for JWT-based authentication with rotation
/// Stores hashed refresh tokens to detect reuse and enable session invalidation
model RefreshToken {
  id                String   @id @default(cuid())
  merchant          Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId        String
  /// Hashed token value (bcrypt cost 12)
  token_hash        String   @unique
  /// Token expiration (30 days from creation)
  expires_at        DateTime
  /// Whether this token has been invalidated (logout or rotation)
  is_revoked        Boolean  @default(false)
  /// Set to true if a reused token was detected (security incident)
  is_reused         Boolean  @default(false)
  /// IP address of the client that created this token
  created_at_ip     String?
  /// User agent of the client that created this token
  created_at_user_agent String?
  created_at        DateTime @default(now())
  revoked_at        DateTime?

  @@index([merchantId])
  @@index([token_hash])
  @@index([expires_at])
}

/// Tracks failed login attempts for account lockout
model LoginAttempt {
  id                String   @id @default(cuid())
  merchantId        String
  /// Email used for login attempt
  email             String
  /// IP address of the attempt
  ip_address        String
  /// Whether the attempt was successful
  success           Boolean  @default(false)
  created_at        DateTime @default(now())

  @@index([merchantId])
  @@index([email])
  @@index([ip_address])
  @@index([created_at])
}

/// Logs rate limit events for monitoring and abuse detection
model RateLimitLog {
  id                String   @id @default(cuid())
  ip_address        String
  endpoint          String
  limit_type        String
  retry_after_seconds Int
  timestamp         DateTime @default(now())

  @@index([ip_address])
  @@index([timestamp])
  @@index([limit_type])
}

enum DepositAddressStatus {
  available
  assigned
  cooldown
}

model DepositAddress {
  id                 String               @id @default(cuid())
  public_key         String               @unique
  secret_key         String               // encrypted
  derivation_path    String
  status             DepositAddressStatus @default(available)
  assigned_payment_id String?             @unique
  payment            Payment?             @relation(fields: [assigned_payment_id], references: [id])
  cooldown_until     DateTime?
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt

  @@index([status, cooldown_until])
}
